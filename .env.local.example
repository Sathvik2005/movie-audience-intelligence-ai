# AI Movie Insight Builder — Environment Variables
# Copy this file to .env.local and fill in your keys

# OMDb API Key — Get from: https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_api_key_here

# TMDB API Key — Get from: https://developer.themoviedb.org/
TMDB_API_KEY=your_tmdb_api_key_here

# OpenAI API Key — Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
